<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dms_file_form_pdf_tools" model="ir.ui.view">
        <field name="name">dms.file.form.pdf.tools</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_form"/>
        <field name="arch" type="xml">
             <xpath expr="//header" position="inside">
                 <button name="%(dms_pdf_tools.action_dms_pdf_split)d" 
                         string="Split PDF" 
                         type="action" 
                         class="btn-secondary"
                         context="{'default_file_id': id}"
                         invisible="mimetype != 'application/pdf'"/>
             </xpath>
        </field>
    </record>
</odoo>
