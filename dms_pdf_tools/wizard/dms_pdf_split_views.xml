<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dms_pdf_split_form" model="ir.ui.view">
        <field name="name">dms.pdf.split.form</field>
        <field name="model">dms.pdf.split</field>
        <field name="arch" type="xml">
            <form string="Split PDF">
                <group>
                    <field name="file_id" invisible="1"/>
                    <field name="mode"/>
                    <field name="page_range" 
                           invisible="mode == 'all'" 
                           required="mode == 'range'" 
                           placeholder="e.g. 1-3, 5, 8-10"/>
                </group>
                <footer>
                    <button string="Split" name="action_split" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dms_pdf_split" model="ir.actions.act_window">
        <field name="name">Split PDF</field>
        <field name="res_model">dms.pdf.split</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
