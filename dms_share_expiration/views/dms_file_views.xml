<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend file form to add share link buttons -->
    <record id="view_dms_file_form_share_links" model="ir.ui.view">
        <field name="name">dms.file.form.share.links</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_share_links" type="object" class="oe_stat_button" icon="fa-link">
                    <field name="share_link_count" widget="statinfo" string="Share Links"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_share_link" string="Create Share Link" type="object" class="btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>
